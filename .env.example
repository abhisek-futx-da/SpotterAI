# ─── SpotterAI Environment Variables ───────────────────────────────────────────
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git — it is already in .gitignore.
# Generate keys at the URLs listed below each variable.


# ─── Django Core ────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=change-me-generate-with-the-command-above

# Set to 1 for local development, 0 (or omit) for production
DJANGO_DEBUG=1

# Comma-separated list of allowed hostnames in production
# Example: DJANGO_ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# Required for production CSRF protection (comma-separated, include https://)
# Example: DJANGO_CSRF_TRUSTED_ORIGINS=https://yourdomain.com
DJANGO_CSRF_TRUSTED_ORIGINS=


# ─── Database ───────────────────────────────────────────────────────────────────
# Optional: override SQLite path (useful for Railway persistent volumes)
# SQLITE_PATH=/data/db.sqlite3


# ─── BLS.gov (Bureau of Labor Statistics) ───────────────────────────────────────
# Free registration: https://data.bls.gov/registrationEngine/
# Used for: Trucking PPI (rate trends), Trucking Employment (capacity signal)
# Rate limit: 25 requests/day without key, 500/day with key
BLS_API_KEY=your-bls-api-key-here


# ─── EIA (Energy Information Administration) ────────────────────────────────────
# Free registration: https://www.eia.gov/opendata/register.php
# Used for: Weekly diesel prices by state, Natural gas prices (Henry Hub for reefer)
# Rate limit: None documented — generous free tier
EIA_API_KEY=your-eia-api-key-here


# ─── FRED (Federal Reserve Economic Data) ───────────────────────────────────────
# Free registration: https://fred.stlouisfed.org/docs/api/api_key.html
# Used for: Truck freight volume, Cass Freight Index, industrial production
# Rate limit: 120 requests/minute free tier
FRED_API_KEY=your-fred-api-key-here


# ─── FMCSA (Federal Motor Carrier Safety Administration) ────────────────────────
# Free registration: https://mobile.fmcsa.dot.gov/developer/home.page
# Used for: Carrier verification (DOT number → operating authority, safety rating)
# Rate limit: None documented — free public API
FMCSA_WEBKEY=your-fmcsa-webkey-here


# ─── Anthropic (Claude AI) ──────────────────────────────────────────────────────
# Registration: https://console.anthropic.com/
# Free credits on signup (~$5 = thousands of broker coaching calls)
# Used for: AI negotiation coach (falls back to rule-based if key is missing)
ANTHROPIC_API_KEY=your-anthropic-api-key-here


# ─── USDA (Optional — reefer produce lanes only) ────────────────────────────────
# Free registration: https://apps.fas.usda.gov/psdonline/app/index.html
# Used for: USDA produce market rates (reefer lane calibration)
USDA_API_KEY=


# ─── Rate Limiting ──────────────────────────────────────────────────────────────
# Max API requests per IP per window (default: 30 per 60s)
# API_RATE_LIMIT=30
# API_RATE_WINDOW_SECONDS=60
