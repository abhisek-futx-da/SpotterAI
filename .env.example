# Copy to .env and fill in values. run.sh sources this locally;
# on Railway set these as service environment variables instead.

# --- Django ---
# Required in production (DJANGO_DEBUG=0). Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=your_secret_key_here
# 1 for local development, 0 (or unset) in production
DJANGO_DEBUG=1
# Comma-separated, e.g. myapp.up.railway.app
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
# Comma-separated origins with scheme, e.g. https://myapp.up.railway.app
DJANGO_CSRF_TRUSTED_ORIGINS=

# --- Data source API keys (all free) ---
# BLS trucking PPI + employment — free key at data.bls.gov/registrationEngine
BLS_API_KEY=your_bls_key_here
# EIA diesel + natural gas prices — free key at eia.gov/opendata
EIA_API_KEY=your_eia_key_here
# FRED economic signals — free key at fred.stlouisfed.org
FRED_API_KEY=your_fred_key_here
# USDA produce truck rates (report 2375 FVWTRK) — free key at usda.gov
USDA_API_KEY=your_usda_key_here
# FMCSA carrier verification — free webKey at mobile.fmcsa.dot.gov/QCDevsite
FMCSA_WEBKEY=your_fmcsa_webkey_here
# AI negotiation coach (optional — falls back to rule-based coach if unset)
ANTHROPIC_API_KEY=your_anthropic_key_here

# --- API abuse protection ---
# Per-IP requests allowed per window on /api/ (0 disables)
API_RATE_LIMIT=30
API_RATE_WINDOW_SECONDS=60
